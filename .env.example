# All optional — the app builds and runs fully without them (fallback mode).

# Supabase project (Settings → API). Anon key only; never the service role key.
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apple Services affiliate token, appended to Apple Music links as ?at=...
NEXT_PUBLIC_APPLE_AFFILIATE_TOKEN=

# Optional static Spotify PKCE playlist export. Client ID only; no client secret.
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# CI-only catalog refresh. Never expose this as NEXT_PUBLIC_*.
ENABLE_CATALOG_REFRESH=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# CI/dev-only card image generation (scripts/generate-card-images.ts). Never NEXT_PUBLIC_*.
OPENAI_API_KEY=
